CELULA_EMAIL=seu-email@dominio.com
CELULA_PASSWORD=sua-senha-aqui
CELULA_ACCOUNT=edificando
CELULA_APP_URL=https://app.celula.in
CELULA_API_HOST=api.celula.in
# Opcional: sobrescreve base da API (default: https://$CELULA_API_HOST)
CELULA_API_BASE=https://api.celula.in
# Obrigatorio para extracao automatizada de frequencia
CELULA_GROUP_ID=61f2d4aa578b3700190c5bb8
# Opcional: limita quantidade de eventos mais recentes (0 = todos)
CELULA_MAX_EVENTS=0
# Opcional: rota que deseja abrir apos login para disparar chamadas
CELULA_TARGET_PATH=/app/cell/61f2d4aa578b3700190c5bb8/events/new
# Opcional: lista de rotas separadas por virgula (tem prioridade sobre CELULA_TARGET_PATH)
CELULA_TARGET_PATHS=/app/cell/61f2d4aa578b3700190c5bb8/events,/app/cell/61f2d4aa578b3700190c5bb8/events/new
# Opcional: textos para clicar automaticamente apos abrir cada rota
CELULA_CLICK_TEXTS=Lancar frequencia,Frequencia,Eventos,Historico
# Opcional: se informado, ignora login UI e usa Authorization Bearer
CELULA_TOKEN=
# Opcional: false para abrir com interface
PLAYWRIGHT_HEADLESS=true
